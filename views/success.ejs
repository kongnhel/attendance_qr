<!DOCTYPE html>
<html lang="km">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Attendance Success</title>
    <link rel="icon" type="image/jpeg" href="/images/favicon.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Hanuman:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
      body {
        font-family: "Plus Jakarta Sans", "Hanuman", sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background: linear-gradient(160deg, #f0fdf4 0%, #ecfdf5 30%, #f0f9ff 70%, #eff6ff 100%);
        position: relative;
        overflow: hidden;
      }
      body::before {
        content: '';
        position: absolute;
        top: -40%;
        right: -20%;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(34,197,94,0.08) 0%, transparent 70%);
        border-radius: 50%;
        animation: float1 10s ease-in-out infinite alternate;
      }
      body::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -15%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 70%);
        border-radius: 50%;
        animation: float2 12s ease-in-out infinite alternate;
      }
      @keyframes float1{0%{transform:translate(0,0)}100%{transform:translate(30px,20px)}}
      @keyframes float2{0%{transform:translate(0,0)}100%{transform:translate(-20px,-30px)}}

      .wrapper{width:100%;max-width:440px;position:relative;z-index:1}

      .brand-bar{text-align:center;margin-bottom:24px;animation:fadeDown .5s ease-out}
      @keyframes fadeDown{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:translateY(0)}}
      .brand-bar .logo{
        width:80px;height:80px;
        border-radius:50%;display:inline-flex;align-items:center;justify-content:center;
        box-shadow:0 8px 24px rgba(22,163,74,0.2);margin-bottom:14px;
        overflow:hidden;
      }
      .brand-bar .logo img{width:100%;height:100%;object-fit:cover;border-radius:50%}
      .brand-bar h1{color:#0f172a;font-size:22px;font-weight:800;letter-spacing:-.03em;margin-bottom:4px}
      .brand-bar p{color:#94a3b8;font-size:13px;font-weight:500}

      .card{
        background:#fff;border-radius:24px;padding:44px 32px 36px;text-align:center;
        box-shadow:0 4px 6px -1px rgba(0,0,0,.03),0 20px 50px -12px rgba(0,0,0,.06);
        border:1px solid rgba(0,0,0,.04);animation:cardUp .5s ease-out .1s both;
      }
      @keyframes cardUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

      .icon-ring{
        width:88px;height:88px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;
        margin-bottom:24px;position:relative;animation:popIn .5s cubic-bezier(.175,.885,.32,1.275) .2s both;
      }
      .icon-ring.success{background:linear-gradient(135deg,#dcfce7,#bbf7d0);box-shadow:0 8px 32px rgba(34,197,94,.15)}
      .icon-ring.error{background:linear-gradient(135deg,#fee2e2,#fecaca);box-shadow:0 8px 32px rgba(239,68,68,.15)}
      @keyframes popIn{from{opacity:0;transform:scale(.5)}to{opacity:1;transform:scale(1)}}

      .icon-ring .check-svg{animation:drawCheck .5s ease-out .5s both}
      @keyframes drawCheck{from{stroke-dashoffset:30}to{stroke-dashoffset:0}}

      .icon-ring i{font-size:36px}
      .icon-ring.success i{color:#16a34a}
      .icon-ring.error i{color:#dc2626}

      .title{font-size:22px;font-weight:800;color:#0f172a;margin-bottom:8px;letter-spacing:-.02em}
      .message{color:#64748b;font-size:14px;line-height:1.7;margin-bottom:28px}

      .divider{height:1px;background:linear-gradient(90deg,transparent,#e2e8f0,transparent);margin-bottom:24px}

      .info-row{
        display:flex;align-items:center;gap:10px;padding:12px 16px;
        background:#f8fafc;border-radius:12px;margin-bottom:10px;
        animation:fieldUp .4s ease-out .3s both;
      }
      @keyframes fieldUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
      .info-row .info-icon{
        width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;
        flex-shrink:0;font-size:14px;
      }
      .info-row .info-icon.green{background:#dcfce7;color:#16a34a}
      .info-row .info-icon.blue{background:#dbeafe;color:#2563eb}
      .info-row .info-icon.purple{background:#f3e8ff;color:#9333ea}
      .info-row .info-label{font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:.05em;font-weight:600}
      .info-row .info-value{font-size:14px;color:#0f172a;font-weight:600}

      .btn-group{display:flex;gap:10px;margin-top:24px;animation:fieldUp .4s ease-out .4s both}
      .btn{
        flex:1;padding:13px;border-radius:12px;font-size:14px;font-weight:600;font-family:inherit;
        cursor:pointer;border:none;display:flex;align-items:center;justify-content:center;gap:8px;
        transition:all .25s ease;text-decoration:none;
      }
      .btn-primary{
        background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;
        box-shadow:0 4px 16px rgba(22,163,74,.25);
      }
      .btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(22,163,74,.35)}
      .btn-secondary{
        background:#f1f5f9;color:#475569;border:1.5px solid #e2e8f0;
      }
      .btn-secondary:hover{background:#e2e8f0;transform:translateY(-1px)}

      .footer-note{
        text-align:center;margin-top:20px;color:#94a3b8;font-size:11px;
        animation:fieldUp .4s ease-out .5s both;
      }
      .footer-note i{color:#22c55e}

      @media(prefers-reduced-motion:reduce){
        *,*::before,*::after{animation-duration:0.01ms !important;animation-iteration-count:1 !important;transition-duration:0.01ms !important}
        body::before,body::after{animation:none !important}
      }
      @media(prefers-reduced-motion:reduce),(max-width:480px){
        .card-up,.fadeDown,.cardUp,.popIn,.fieldUp{animation:none !important;opacity:1 !important;transform:none !important}
      }
      @media(max-width:400px){
        .card{padding:36px 20px 28px}
        .brand-bar h1{font-size:19px}
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="brand-bar">
        <div class="logo"><img src="/images/logo.jpg" alt="Logo" loading="lazy" width="80" height="80" /></div>
        <h1>QR Attendance</h1>
        <p>ប្រព័ន្ធកត់ត្រាវត្តមាន</p>
      </div>

      <div class="card">
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="icon-ring success">
            <i class="fa-solid fa-check"></i>
          </div>
          <h1 class="title">ជោគជ័យ!</h1>
          <p class="message"><%= message %></p>

          <div class="divider"></div>

          <% if (typeof name !== 'undefined' && name) { %>
          <div class="info-row">
            <div class="info-icon green"><i class="fa-solid fa-user"></i></div>
            <div>
              <div class="info-label">ឈ្មោះ</div>
              <div class="info-value"><%= name %></div>
            </div>
          </div>
          <% } %>

          <div class="info-row" style="animation-delay:.35s">
            <div class="info-icon blue"><i class="fa-solid fa-clock"></i></div>
            <div>
              <div class="info-label">ពេលវេលា</div>
              <div class="info-value"><%= typeof currentTime !== 'undefined' ? currentTime : '' %></div>
            </div>
          </div>

          <div class="info-row" style="animation-delay:.4s">
            <div class="info-icon purple"><i class="fa-solid fa-calendar"></i></div>
            <div>
              <div class="info-label">ថ្ងៃនេះ</div>
              <div class="info-value"><%= typeof currentDate !== 'undefined' ? currentDate : '' %></div>
            </div>
          </div>

          <div class="btn-group">
            <a href="/scan" class="btn btn-primary">
              <i class="fa-solid fa-rotate-right"></i> ស្កេនថ្មី
            </a>
            <a href="/" class="btn btn-secondary">
              <i class="fa-solid fa-house"></i> ទំព័រដើម
            </a>
          </div>

        <% } else { %>
          <div class="icon-ring error">
            <i class="fa-solid fa-xmark"></i>
          </div>
          <h1 class="title">បរាជ័យ</h1>
          <p class="message"><%= typeof message !== 'undefined' ? message : 'មានបញ្ហាក្នុងការកត់ត្រាវត្តមាន។' %></p>

          <div class="divider"></div>

          <div class="btn-group">
            <a href="/scan" class="btn btn-primary">
              <i class="fa-solid fa-rotate-right"></i> ព្យាយាមម្តងទៀត
            </a>
            <a href="/scan" class="btn btn-secondary">
              <i class="fa-solid fa-house"></i> ទំព័រដើម
            </a>
          </div>
        <% } %>
      </div>

      <div class="footer-note">
        <i class="fa-solid fa-shield-halved"></i> ទិន្នន័យរបស់អ្នកត្រូវបានការពារដោយសុវត្ថិភាព
      </div>
    </div>
  </body>
</html>
