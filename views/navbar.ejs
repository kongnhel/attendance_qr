<nav
  style="
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 14px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    border-radius: 16px;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.4);
    font-family:
      &quot;Inter&quot;,
      &quot;Hanuman&quot;,
      &quot;Khmer OS&quot;,
      -apple-system,
      BlinkMacSystemFont,
      &quot;Segoe UI&quot;,
      Roboto,
      sans-serif;
  "
>
  <div style="display: flex; gap: 12px; align-items: center">
    <a
      href="/manager/qr"
      style="
        color: #1e293b;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 12px;
        transition: all 0.2s ease-in-out;
      "
      class="nav-link-item"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="3" y="3" width="7" height="7"></rect>
        <rect x="14" y="3" width="7" height="7"></rect>
        <rect x="14" y="14" width="7" height="7"></rect>
        <rect x="3" y="14" width="7" height="7"></rect>
      </svg>
      <span class="nav-text"><%= __('nav_qr') %></span>
    </a>

    <a
      href="/manager/list"
      style="
        color: #1e293b;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 12px;
        transition: all 0.2s ease-in-out;
      "
      class="nav-link-item"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="8" y1="6" x2="21" y2="6"></line>
        <line x1="8" y1="12" x2="21" y2="12"></line>
        <line x1="8" y1="18" x2="21" y2="18"></line>
        <line x1="3" y1="6" x2="3.01" y2="6"></line>
        <line x1="3" y1="12" x2="3.01" y2="12"></line>
        <line x1="3" y1="18" x2="3.01" y2="18"></line>
      </svg>
      <span class="nav-text"><%= __('nav_list') %></span>
    </a>
  </div>

  <div style="display: flex; gap: 14px; align-items: center">
    <div
      style="
        display: flex;
        gap: 4px;
        background: #f1f5f9;
        padding: 4px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
      "
    >
      <a
        href="?lang=km"
        style="
                text-decoration: none; 
                padding: 6px 12px; 
                font-size: 12px; 
                border-radius: 7px; 
                font-weight: 700;
                transition: all 0.2s ease;
                <%= currentLang === 'km' ? 'background: #ffffff; color: #0f172a; box-shadow: 0 2px 6px rgba(0,0,0,0.08);' : 'color: #64748b;' %>
            "
        class="lang-btn"
        >KM</a
      >
      <a
        href="?lang=en"
        style="
                text-decoration: none; 
                padding: 6px 12px; 
                font-size: 12px; 
                border-radius: 7px; 
                font-weight: 700;
                transition: all 0.2s ease;
                <%= currentLang === 'en' ? 'background: #ffffff; color: #0f172a; box-shadow: 0 2px 6px rgba(0,0,0,0.08);' : 'color: #64748b;' %>
            "
        class="lang-btn"
        >EN</a
      >
    </div>

    <a
      href="/admin/logout"
      style="
        background-color: #fef2f2;
        color: #ef4444;
        padding: 10px 18px;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 14px;
        border: 1px solid #fee2e2;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s ease-in-out;
      "
      class="logout-btn"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
        <polyline points="16 17 21 12 16 7"></polyline>
        <line x1="21" y1="12" x2="9" y2="12"></line>
      </svg>
      <span class="logout-text"><%= __('nav_logout') %></span>
    </a>
  </div>
</nav>

<style>
  /* គ្រប់គ្រង Hover Effect លើ Tabs */
  .nav-link-item:hover {
    background-color: #f1f5f9;
    color: #0f172a !important;
  }

  /* គ្រប់គ្រង Hover Effect លើប៊ូតុងប្តូរភាសាដែលមិនទាន់ Active */
  .lang-btn:not([style*="background: #ffffff"]):hover {
    color: #0f172a !important;
    background-color: rgba(0, 0, 0, 0.04);
  }

  /* គ្រប់គ្រង Hover Effect លើប៊ូតុង Logout */
  .logout-btn:hover {
    background-color: #ef4444 !important;
    color: #ffffff !important;
    border-color: #ef4444 !important;
  }

  /* Responsive Design: បង្រួញអក្សរពេលមើលលើទូរស័ព្ទដៃដើម្បីកុំឱ្យហៀរអេក្រង់ */
  @media (max-width: 640px) {
    .nav-text,
    .logout-text {
      display: none;
    }
    .nav-link-item {
      padding: 10px !important;
    }
    .logout-btn {
      padding: 10px !important;
    }
  }
</style>
