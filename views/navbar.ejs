</nav>

<style>
  .navbar{
    background:#fff;
    padding:12px 20px;
    display:flex;justify-content:space-between;align-items:center;
    margin-bottom:24px;
    border-radius:16px;
    box-shadow:0 1px 3px rgba(0,0,0,.04),0 4px 12px rgba(0,0,0,.03);
    border:1px solid rgba(0,0,0,.04);
    font-family:"Plus Jakarta Sans","Hanuman",sans-serif;
    max-width:1200px;margin-left:auto;margin-right:auto;
  }
  .nav-left,.nav-right{display:flex;gap:8px;align-items:center}
  .nav-link-item{
    color:#475569;text-decoration:none;font-weight:600;font-size:13px;
    display:flex;align-items:center;gap:7px;
    padding:9px 14px;border-radius:10px;transition:all .2s ease;
  }
  .nav-link-item:hover{background:#f0fdf4;color:#16a34a}
  .nav-link-item i{font-size:14px}

  .lang-switcher{
    display:flex;gap:3px;background:#f1f5f9;padding:3px;border-radius:8px;border:1px solid #e2e8f0;
  }
  .lang-btn{
    text-decoration:none;padding:5px 10px;font-size:11px;border-radius:6px;
    font-weight:700;color:#94a3b8;transition:all .2s ease;
  }
  .lang-btn.active{background:#fff;color:#0f172a;box-shadow:0 1px 4px rgba(0,0,0,.08)}
  .lang-btn:hover:not(.active){color:#475569;background:rgba(0,0,0,.03)}

  .logout-btn{
    background:#fef2f2;color:#ef4444;padding:9px 14px;text-decoration:none;
    border-radius:10px;font-weight:600;font-size:13px;border:1px solid #fee2e2;
    display:inline-flex;align-items:center;gap:6px;transition:all .2s ease;
  }
  .logout-btn:hover{background:#ef4444;color:#fff;border-color:#ef4444}
  .logout-btn i{font-size:13px}

  @media(max-width:640px){
    .nav-text,.logout-text{display:none}
    .nav-link-item{padding:9px !important}
    .logout-btn{padding:9px !important}
    .navbar{padding:10px 14px;margin:0 12px 16px}
  }
</style>
