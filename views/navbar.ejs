<nav class="navbar">
  <div class="nav-left">
    <a href="/manager/qr" class="nav-link-item">
      <i class="fa-solid fa-qrcode"></i>
      <span class="nav-text"><%= __('nav_qr') %></span>
    </a>
    <a href="/manager/list" class="nav-link-item">
      <i class="fa-solid fa-list"></i>
      <span class="nav-text"><%= __('nav_list') %></span>
    </a>
  </div>
  <div class="nav-right">
    <div class="lang-switcher">
      <a href="?lang=km" class="lang-btn <%= currentLang === 'km' ? 'active' : '' %>">KM</a>
      <a href="?lang=en" class="lang-btn <%= currentLang === 'en' ? 'active' : '' %>">EN</a>
    </div>
    <a href="/admin/logout" class="logout-btn">
      <i class="fa-solid fa-right-from-bracket"></i>
