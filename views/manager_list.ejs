<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken %>">
    
    <title><%= __('nav_list') %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Hanuman:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
    
    <style>
        body { 
            font-family: 'Inter', 'Hanuman', 'Khmer OS', 'Khmer OS Battambang', sans-serif; 
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen text-gray-800">

    <%- include('navbar') %>

    <div class="max-w-6xl mx-auto px-4 py-6">
        
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <h1 class="text-xl sm:text-2xl font-bold text-gray-900 flex items-center gap-3">
                    <i class="fa-solid fa-clipboard-user text-green-600"></i>
                    <%= __('list_title') %>
                </h1>
                <p class="text-sm text-gray-500 mt-1">
                    <%= __('list_total') %>: <span class="font-semibold text-gray-800 bg-gray-100 px-2 py-0.5 rounded-full"><%= totalRecords %></span>
                </p>
            </div>
            <div class="w-full sm:w-auto flex flex-col sm:flex-row gap-2">
                <button id="btnAddRecord" data-action="create" class="w-full sm:w-auto inline-flex justify-center items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold py-2.5 px-4 rounded-lg shadow-sm text-sm transition-all duration-200 active:scale-95">
                    <i class="fa-solid fa-plus"></i>
                    <%= __('btn_add') %>
                </button>
                <button id="btnExportExcel" class="w-full sm:w-auto inline-flex justify-center items-center gap-2 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-2.5 px-4 rounded-lg shadow-sm text-sm transition-all duration-200 active:scale-95">
                    <i class="fa-solid fa-file-excel"></i>
                    <%= __('btn_export') %>
                </button>
                <a href="/manager/list?page=<%= currentPage %>" class="w-full sm:w-auto inline-flex justify-center items-center gap-2 bg-white hover:bg-gray-50 text-gray-700 font-medium py-2.5 px-4 border border-gray-300 rounded-lg shadow-sm text-sm transition-all duration-200 active:scale-95">
                    <i class="fa-solid fa-rotate text-blue-500"></i>
                    <%= __('btn_refresh') %>
                </a>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
            <div class="relative">
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                <input type="text" id="searchInput" placeholder="<%= __('search_placeholder') %>" class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm">
            </div>
        </div>

        <% if(records.length === 0) { %>
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 py-12 px-6 text-center text-gray-400">
                <div class="flex flex-col items-center justify-center gap-3">
                    <i class="fa-solid fa-folder-open text-4xl text-gray-300"></i>
                    <p class="text-base font-medium"><%= __('no_records') %></p>
                </div>
            </div>
        <% } else { %>

            <div class="grid grid-cols-1 gap-4 sm:hidden mb-6">
                <% records.forEach((record, index) => { %>
                    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 relative">
                        <div class="flex justify-between items-center border-b border-gray-100 pb-2 mb-3">
                            <span class="text-xs font-bold text-gray-400 font-mono">No. <%= ((currentPage - 1) * 10) + (index + 1) %></span>
                            <div class="flex items-center gap-3">
                                <span class="text-xs font-medium text-gray-500 flex items-center gap-1">
                                    <i class="fa-regular fa-clock text-gray-400"></i> <%= record.time %>
                                </span>
                                <button data-action="edit" data-id="<%= record.id %>" data-name="<%= record.name %>" data-gender="<%= record.gender %>" data-age="<%= record.age %>" data-phone="<%= record.phone %>" data-place="<%= record.place %>" class="btn-edit text-blue-600 hover:text-blue-800 text-xs font-medium"><i class="fa-solid fa-pen"></i></button>
                                <button data-action="delete" data-id="<%= record.id %>" class="btn-delete text-red-600 hover:text-red-800 text-xs font-medium"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </div>
                        
                        <div class="flex items-center justify-between mb-2">
                            <div class="flex items-center gap-2.5">
                                <div class="w-7 h-7 rounded-full bg-green-50 text-green-600 flex items-center justify-center font-bold text-xs uppercase">
                                    <%= record.name.charAt(0) %>
                                </div>
                                <span class="font-semibold text-gray-900 text-sm"><%= record.name %></span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <span class="inline-flex items-center text-[11px] font-semibold bg-purple-50 text-purple-700 px-2 py-0.5 rounded-full"><%= record.age %> ឆ្នាំ</span>
                                <% if(record.gender === 'Male' || record.gender === 'ប្រុស') { %>
                                    <span class="inline-flex items-center gap-1 text-[11px] font-medium bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full"><i class="fa-solid fa-mars"></i> <%= __('gender_male') %></span>
                                <% } else if(record.gender === 'Female' || record.gender === 'ស្រី') { %>
                                    <span class="inline-flex items-center gap-1 text-[11px] font-medium bg-pink-50 text-pink-700 px-2 py-0.5 rounded-full"><i class="fa-solid fa-venus"></i> <%= __('gender_female') %></span>
                                <% } else { %>
                                    <span class="inline-flex items-center gap-1 text-[11px] font-medium bg-gray-50 text-gray-600 px-2 py-0.5 rounded-full"><i class="fa-solid fa-genderless"></i> <%= __('gender_other') %></span>
                                <% } %>
                            </div>
                        </div>

                        <div class="text-xs text-gray-600 space-y-1.5 mt-3 pt-2 border-t border-dashed border-gray-100">
                            <div class="flex items-center gap-2">
                                <i class="fa-solid fa-phone text-gray-400 w-4"></i>
                                <span class="font-mono text-gray-700"><%= record.phone %></span>
                            </div>
                            <div class="flex items-center gap-2">
                                <i class="fa-solid fa-location-dot text-gray-400 w-4"></i>
                                <span class="text-gray-700"><%= record.place %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="hidden sm:block bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100">
                            <th class="py-4 px-6 text-sm font-semibold text-gray-600 uppercase tracking-wider text-center w-20">No.</th>
                            <th class="py-4 px-6 text-sm font-semibold text-gray-600 uppercase tracking-wider"><%= __('th_name') %></th>
                            <th class="py-4 px-6 text-sm font-semibold text-gray-600 uppercase tracking-wider"><%= __('th_gender') %></th>
                            <th class="py-4 px-6 text-sm font-semibold text-gray-600 uppercase tracking-wider"><%= __('th_age') %></th>
                            <th class="py-4 px-6 text-sm font-semibold text-gray-600 uppercase tracking-wider"><%= __('th_phone') %></th>
                            <th class="py-4 px-6 text-sm font-semibold text-gray-600 uppercase tracking-wider"><%= __('th_place') %></th>
                            <th class="py-4 px-6 text-sm font-semibold text-gray-600 uppercase tracking-wider"><%= __('th_time') %></th>
                            <th class="py-4 px-6 text-sm font-semibold text-gray-600 uppercase tracking-wider text-center w-32">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% records.forEach((record, index) => { %>
                            <tr class="hover:bg-gray-50/70 transition-colors duration-150">
                                <td class="py-4 px-6 text-sm font-semibold text-gray-400 text-center font-mono">
                                    <%= ((currentPage - 1) * 10) + (index + 1) %>
                                </td>
                                <td class="py-4 px-6 font-medium text-gray-900 flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-green-50 text-green-600 flex items-center justify-center font-bold text-sm uppercase">
                                        <%= record.name.charAt(0) %>
                                    </div>
                                    <%= record.name %>
                                </td>
                                <td class="py-4 px-6">
                                    <% if(record.gender === 'Male' || record.gender === 'ប្រុស') { %>
                                        <span class="inline-flex items-center gap-1 text-xs font-medium bg-blue-50 text-blue-700 px-2.5 py-1 rounded-full"><i class="fa-solid fa-mars"></i> <%= __('gender_male') %></span>
                                    <% } else if(record.gender === 'Female' || record.gender === 'ស្រី') { %>
                                        <span class="inline-flex items-center gap-1 text-xs font-medium bg-pink-50 text-pink-700 px-2.5 py-1 rounded-full"><i class="fa-solid fa-venus"></i> <%= __('gender_female') %></span>
                                    <% } else { %>
                                        <span class="inline-flex items-center gap-1 text-xs font-medium bg-gray-50 text-gray-600 px-2.5 py-1 rounded-full"><i class="fa-solid fa-genderless"></i> <%= __('gender_other') %></span>
                                    <% } %>
                                </td>
                                <td class="py-4 px-6 text-sm font-semibold text-gray-700 font-mono">
                                    <%= record.age %>
                                </td>
                                <td class="py-4 px-6 text-gray-600 font-mono text-sm"><i class="fa-solid fa-phone text-gray-400 mr-1.5 text-xs"></i><%= record.phone %></td>
                                <td class="py-4 px-6 text-gray-600"><i class="fa-solid fa-location-dot text-gray-400 mr-1.5 text-xs"></i><%= record.place %></td>
                                <td class="py-4 px-6 text-gray-500 font-medium text-sm"><i class="fa-regular fa-clock text-gray-400 mr-1.5 text-xs"></i><%= record.time %></td>
                                <td class="py-4 px-6 text-center">
                                    <div class="inline-flex items-center gap-2">
                                        <button data-action="edit" data-id="<%= record.id %>" data-name="<%= record.name %>" data-gender="<%= record.gender %>" data-age="<%= record.age %>" data-phone="<%= record.phone %>" data-place="<%= record.place %>" class="btn-edit p-1.5 text-blue-600 hover:bg-blue-50 rounded transition-colors" title="Edit"><i class="fa-solid fa-pen-to-square"></i></button>
                                        <button data-action="delete" data-id="<%= record.id %>" class="btn-delete p-1.5 text-red-600 hover:bg-red-50 rounded transition-colors" title="Delete"><i class="fa-solid fa-trash-can"></i></button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <% if (totalPages > 1) { %>
                <div class="flex items-center justify-between border-t border-gray-200 bg-white px-4 py-4 rounded-xl shadow-sm sm:px-6">
                    <div class="flex flex-1 justify-between sm:hidden">
                        <a href="/manager/list?page=<%= currentPage - 1 %>" class="<%= currentPage === 1 ? 'pointer-events-none opacity-40' : '' %> relative inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"><%= __('btn_prev') %></a>
                        <span class="text-sm font-medium self-center text-gray-600"><%= __('page') %> <%= currentPage %> / <%= totalPages %></span>
                        <a href="/manager/list?page=<%= currentPage + 1 %>" class="<%= currentPage === totalPages ? 'pointer-events-none opacity-40' : '' %> relative inline-flex items-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"><%= __('btn_next') %></a>
                    </div>
                    
                    <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
                        <div>
                            <p class="text-sm text-gray-700">
                                <%= __('showing_page') %> <span class="font-medium text-blue-600"><%= currentPage %></span> <%= __('of') %> <span class="font-medium"><%= totalPages %></span> <%= __('pages') %>
                            </p>
                        </div>
                        <div>
                            <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm">
                                <a href="/manager/list?page=<%= currentPage - 1 %>" class="<%= currentPage === 1 ? 'pointer-events-none opacity-40' : '' %> relative inline-flex items-center rounded-l-md px-3 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50">
                                    <i class="fa-solid fa-chevron-left text-xs"></i>
                                </a>
                                <% for(let i = 1; i <= totalPages; i++) { %>
                                    <a href="/manager/list?page=<%= i %>" class="relative inline-flex items-center px-4 py-2 text-sm font-semibold <%= currentPage === i ? 'z-10 bg-blue-600 text-white' : 'text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50' %>"><%= i %></a>
                                <% } %>
                                <a href="/manager/list?page=<%= currentPage + 1 %>" class="<%= currentPage === totalPages ? 'pointer-events-none opacity-40' : '' %> relative inline-flex items-center rounded-r-md px-3 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50">
                                    <i class="fa-solid fa-chevron-right text-xs"></i>
                                </a>
                            </nav>
                        </div>
                    </div>
                </div>
            <% } %>
        <% } %>
    </div>

    <div id="crudModal" class="hidden fixed inset-0 z-50 overflow-y-auto bg-gray-900/40 backdrop-blur-sm items-center justify-center p-4">
        <div class="bg-white rounded-2xl w-full max-w-md shadow-xl border border-gray-100 overflow-hidden transform transition-all">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                <h3 id="modalTitle" class="text-lg font-bold text-gray-900">Add New Attendance</h3>
                <button id="btnCloseModal" class="text-gray-400 hover:text-gray-600"><i class="fa-solid fa-xmark text-lg"></i></button>
            </div>
            
            <form id="crudForm" class="p-6 space-y-4">
                <input type="hidden" id="recordId" name="id">
                
                <input type="hidden" id="csrfInput" value="<%= csrfToken %>"
                       data-add-title="<%= __('modal_add_title') %>"
                       data-edit-title="<%= __('modal_edit_title') %>"
                       data-swal-success="<%= __('swal_success') %>"
                       data-swal-saved="<%= __('swal_saved') %>"
                       data-swal-error="<%= __('swal_error') %>"
                       data-swal-fail-msg="<%= __('swal_fail_msg') %>"
                       data-swal-confirm-title="<%= __('swal_confirm_title') %>"
                       data-swal-confirm-text="<%= __('swal_confirm_text') %>"
                       data-swal-confirm-btn="<%= __('swal_confirm_btn') %>"
                       data-swal-cancel-btn="<%= __('swal_cancel_btn') %>"
                       data-swal-deleted-title="<%= __('swal_deleted_title') %>"
                       data-swal-deleted-msg="<%= __('swal_deleted_msg') %>"
                       data-swal-delete-fail="<%= __('swal_delete_fail') %>">
                
                <div>
                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-1"><%= __('th_name') %></label>
                    <input type="text" id="formName" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm">
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-1"><%= __('th_gender') %></label>
                    <select id="formGender" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm">
                        <option value="Male"><%= __('gender_male') %></option>
                        <option value="Female"><%= __('gender_female') %></option>
                        <option value="Other"><%= __('gender_other') %></option>
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-1"><%= __('th_age') %></label>
                    <input type="number" id="formAge" required min="1" max="120" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm font-mono" placeholder="ឧទាហរណ៍៖ ២២">
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-1"><%= __('th_phone') %></label>
                    <input type="tel" id="formPhone" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm font-mono">
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-1"><%= __('th_place') %></label>
                    <input type="text" id="formPlace" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm">
                </div>
                
                <div class="flex justify-end gap-2 pt-2">
                    <button type="button" id="btnCancelModal" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg font-medium text-sm transition-colors"><%= __('btn_cancel') %></button>
                    <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold text-sm shadow-sm transition-colors"><%= __('btn_save') %></button>
                </div>
            </form>
        </div>
    </div>

    <script src="/js/manager-list.js"></script>
    <div id="recordsData" data-records="<%- JSON.stringify(records).replace(/"/g, '&quot;') %>" class="hidden"></div>
    <script src="/js/manager-list-search.js"></script>
</body>
</html>