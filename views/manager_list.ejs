<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken %>">
    <title><%= __('nav_list') %></title>
    <link rel="icon" type="image/jpeg" href="/images/favicon.jpg" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Hanuman:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
      body{
        font-family:"Plus Jakarta Sans","Hanuman",sans-serif;
        background:linear-gradient(160deg,#f0fdf4 0%,#ecfdf5 30%,#f0f9ff 70%,#eff6ff 100%);
        min-height:100vh;color:#0f172a;position:relative;
      }
      .page-wrapper{max-width:1100px;margin:0 auto;padding:20px 16px}
      .page-bg{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}
      .page-bg::before{
        content:'';position:absolute;top:-40%;right:-20%;width:600px;height:600px;
        background:radial-gradient(circle,rgba(34,197,94,0.07) 0%,transparent 70%);border-radius:50%;
      }
      .page-bg::after{
        content:'';position:absolute;bottom:-30%;left:-15%;width:500px;height:500px;
        background:radial-gradient(circle,rgba(59,130,246,0.05) 0%,transparent 70%);border-radius:50%;
      }

      .header-card{
        background:#fff;border-radius:20px;padding:24px 28px;margin-bottom:20px;
        box-shadow:0 1px 3px rgba(0,0,0,.03),0 8px 24px rgba(0,0,0,.03);
        border:1px solid rgba(0,0,0,.04);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;
        animation:fadeUp .4s ease-out;
      }
      @keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
      .header-title{display:flex;align-items:center;gap:12px}
      .header-icon{
        width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;
        overflow:hidden;
      }
      .header-icon img{width:100%;height:100%;object-fit:cover;border-radius:50%}
      .header-title h1{font-size:20px;font-weight:700;color:#0f172a}
      .header-title p{font-size:13px;color:#94a3b8;margin-top:2px}
      .header-title .badge{
        display:inline-flex;align-items:center;gap:4px;background:#f0fdf4;color:#16a34a;
        padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;border:1px solid #dcfce7;
      }
      .header-actions{display:flex;gap:8px;flex-wrap:wrap}
      .btn{
        display:inline-flex;align-items:center;gap:7px;padding:10px 18px;border-radius:11px;
        font-size:13px;font-weight:600;font-family:inherit;cursor:pointer;border:none;
        transition:all .2s ease;text-decoration:none;white-space:nowrap;
      }
      .btn-green{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;box-shadow:0 2px 8px rgba(22,163,74,0.2)}
      .btn-green:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(22,163,74,0.3)}
      .btn-emerald{background:linear-gradient(135deg,#10b981,#059669);color:#fff;box-shadow:0 2px 8px rgba(16,185,129,0.2)}
      .btn-emerald:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(16,185,129,0.3)}
      .btn-outline{background:#fff;color:#475569;border:1.5px solid #e2e8f0}
      .btn-outline:hover{background:#f8fafc;border-color:#cbd5e1}

      .search-card{
        background:#fff;border-radius:16px;padding:14px 18px;margin-bottom:20px;
        box-shadow:0 1px 3px rgba(0,0,0,.03);border:1px solid rgba(0,0,0,.04);
        animation:fadeUp .4s ease-out .05s both;
      }
      .search-wrap{position:relative}
      .search-wrap i{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:14px}
      .search-input{
        width:100%;padding:11px 14px 11px 40px;background:#f8fafc;border:1.5px solid #e2e8f0;
        border-radius:10px;font-size:14px;font-family:inherit;color:#0f172a;outline:none;transition:all .2s;
      }
      .search-input::placeholder{color:#94a3b8}
      .search-input:focus{border-color:#22c55e;background:#fff;box-shadow:0 0 0 3px rgba(34,197,94,0.08)}

      .empty-state{
        background:#fff;border-radius:20px;padding:48px 24px;text-align:center;
        box-shadow:0 1px 3px rgba(0,0,0,.03);border:1px solid rgba(0,0,0,.04);
        animation:fadeUp .4s ease-out .1s both;
      }
      .empty-state i{font-size:40px;color:#e2e8f0;margin-bottom:12px}
      .empty-state p{color:#94a3b8;font-size:14px;font-weight:500}

      .table-card{
        background:#fff;border-radius:20px;overflow:hidden;
        box-shadow:0 1px 3px rgba(0,0,0,.03),0 8px 24px rgba(0,0,0,.03);
        border:1px solid rgba(0,0,0,.04);animation:fadeUp .4s ease-out .1s both;
      }
      .table-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch}
      .table-card table{width:100%;border-collapse:collapse;table-layout:fixed}
      .table-card thead{background:#f8fafc}
      .table-card th{
        padding:14px 18px;text-align:left;font-size:11px;font-weight:700;
        color:#64748b;text-transform:uppercase;letter-spacing:.06em;
        border-bottom:1px solid #f1f5f9;white-space:nowrap;
      }
      .table-card td{padding:14px 18px;border-bottom:1px solid #f8fafc;font-size:13px}
      .table-card tbody tr{transition:background .15s}
      .table-card tbody tr:hover{background:#f8fafc}

      .avatar-sm{
        width:34px;height:34px;border-radius:10px;display:inline-flex;align-items:center;justify-content:center;
        font-weight:700;font-size:13px;text-transform:uppercase;
      }
      .avatar-green{background:#dcfce7;color:#16a34a}

      .badge-pill{
        display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:20px;
        font-size:11px;font-weight:600;
      }
      .badge-blue{background:#dbeafe;color:#2563eb}
      .badge-pink{background:#fce7f3;color:#db2777}
      .badge-purple{background:#f3e8ff;color:#9333ea}
      .badge-gray{background:#f1f5f9;color:#64748b}

      .action-btn{
        width:32px;height:32px;border-radius:8px;border:none;cursor:pointer;
        display:inline-flex;align-items:center;justify-content:center;
        transition:all .15s;font-size:13px;
      }
      .action-edit{background:#eff6ff;color:#2563eb}
      .action-edit:hover{background:#dbeafe}
      .action-delete{background:#fef2f2;color:#dc2626}
      .action-delete:hover{background:#fee2e2}

      .pagination{
        display:flex;align-items:center;justify-content:space-between;
        padding:16px 20px;border-top:1px solid #f1f5f9;
      }
      .pagination .info{font-size:13px;color:#64748b}
      .pagination .info span{font-weight:600;color:#2563eb}
      .page-btns{display:flex;gap:4px}
      .page-btn{
        width:34px;height:34px;border-radius:8px;border:1.5px solid #e2e8f0;background:#fff;
        display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;
        color:#475569;cursor:pointer;text-decoration:none;transition:all .15s;
      }
      .page-btn:hover{background:#f8fafc;border-color:#cbd5e1}
      .page-btn.active{background:#22c55e;color:#fff;border-color:#22c55e}
      .page-btn.disabled{opacity:.4;pointer-events:none}

      .modal-overlay{
        position:fixed;inset:0;z-index:50;background:rgba(0,0,0,.4);
        display:none;align-items:center;justify-content:center;padding:16px;
      }
      .modal-overlay.show{display:flex}
      .modal-box{
        background:#fff;border-radius:20px;width:100%;max-width:440px;
        box-shadow:0 20px 60px rgba(0,0,0,.12);animation:modalIn .25s ease-out;
      }
      @keyframes modalIn{from{opacity:0;transform:scale(.95) translateY(8px)}to{opacity:1;transform:scale(1) translateY(0)}}
      .modal-header{
        padding:20px 24px 16px;border-bottom:1px solid #f1f5f9;
        display:flex;align-items:center;justify-content:space-between;
      }
      .modal-header h3{font-size:17px;font-weight:700;color:#0f172a}
      .modal-close{
        width:32px;height:32px;border-radius:8px;border:none;background:#f1f5f9;
        color:#64748b;cursor:pointer;display:flex;align-items:center;justify-content:center;
        transition:all .15s;font-size:14px;
      }
      .modal-close:hover{background:#e2e8f0;color:#0f172a}
      .modal-body{padding:20px 24px 24px}
      .modal-body .form-group{margin-bottom:16px}
      .modal-body label{display:block;font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
      .modal-body input,.modal-body select{
        width:100%;padding:11px 14px;background:#f8fafc;border:1.5px solid #e2e8f0;
        border-radius:10px;font-size:14px;font-family:inherit;color:#0f172a;outline:none;transition:all .2s;
      }
      .modal-body input:focus,.modal-body select:focus{border-color:#22c55e;background:#fff;box-shadow:0 0 0 3px rgba(34,197,94,0.08)}
      .modal-footer{display:flex;justify-content:flex-end;gap:8px;padding-top:8px}
      .modal-footer .btn-cancel{background:#f1f5f9;color:#475569}
      .modal-footer .btn-cancel:hover{background:#e2e8f0}
      .modal-footer .btn-save{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;box-shadow:0 2px 8px rgba(22,163,74,0.2)}
      .modal-footer .btn-save:hover{transform:translateY(-1px);box-shadow:0 4px 12px rgba(22,163,74,0.3)}

      /* Mobile cards - compact with all info */
      .mobile-list{display:none}
      .m-row{
        background:#fff;border-radius:14px;padding:12px 14px;margin-bottom:8px;
        box-shadow:0 1px 2px rgba(0,0,0,.03);border:1px solid rgba(0,0,0,.04);
      }
      .m-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
      .m-left{display:flex;align-items:center;gap:8px;flex:1;min-width:0}
      .m-no{font-size:10px;font-weight:700;color:#94a3b8;font-family:monospace;flex-shrink:0}
      .m-name{font-size:13px;font-weight:600;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
      .m-actions{display:flex;gap:4px;flex-shrink:0}
      .m-badges{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px}
      .m-info{display:flex;flex-wrap:wrap;gap:6px 12px}
      .m-info-item{display:flex;align-items:center;gap:4px;font-size:11px;color:#64748b}
      .m-info-item i{font-size:10px;color:#94a3b8;width:12px;text-align:center}

      /* Performance: disable heavy animations on low-end devices */
      @media(prefers-reduced-motion:reduce){
        *,*::before,*::after{animation-duration:0.01ms !important;animation-iteration-count:1 !important;transition-duration:0.01ms !important}
        .page-bg::before,.page-bg::after{animation:none !important}
      }
      @media(prefers-reduced-motion:reduce),(max-width:480px){
        .card-up,.fadeUp,.fieldUp,.cardUp{animation:none !important;opacity:1 !important;transform:none !important}
      }
      @media(max-width:768px){
        .desktop-table{display:none}
        .mobile-list{display:block}
        .header-card{flex-direction:column;align-items:flex-start;padding:14px 16px;gap:10px;margin-bottom:14px}
        .header-icon{width:32px;height:32px;border-radius:50%}
        .header-title h1{font-size:15px}
        .header-title p{font-size:11px}
        .header-title .badge{font-size:9px;padding:2px 6px}
        .header-actions{width:100%;gap:6px}
        .header-actions .btn{flex:1;justify-content:center;padding:8px 8px;font-size:11px;gap:4px;border-radius:9px}
        .search-card{padding:8px 12px;margin-bottom:12px;border-radius:12px}
        .search-input{padding:8px 10px 8px 32px;font-size:12px;border-radius:9px}
        .search-wrap i{font-size:12px;left:12px}
        .pagination{padding:10px 12px}
        .pagination .info{font-size:11px}
        .page-btn{width:28px;height:28px;font-size:11px;border-radius:7px}
        .page-wrapper{padding:10px 8px}
        .empty-state{padding:32px 16px}
      }
    </style>
</head>
<body>
    <div class="page-bg"></div>

    <div class="page-wrapper">
        <%- include('navbar') %>

        <div class="header-card">
            <div class="header-title">
                <div class="header-icon"><img src="/images/logo.jpg" alt="Logo" loading="lazy" width="44" height="44" /></div>
                <div>
                    <h1><%= __('list_title') %></h1>
                    <p><%= __('list_total') %> <span class="badge"><i class="fa-solid fa-database"></i> <%= totalRecords %></span></p>
                </div>
            </div>
            <div class="header-actions">
                <button id="btnAddRecord" class="btn btn-green"><i class="fa-solid fa-plus"></i> <%= __('btn_add') %></button>
                <button id="btnExportExcel" class="btn btn-emerald"><i class="fa-solid fa-file-excel"></i> <%= __('btn_export') %></button>
                <a href="/manager/list?page=<%= currentPage %>" class="btn btn-outline"><i class="fa-solid fa-rotate"></i> <%= __('btn_refresh') %></a>
            </div>
        </div>

        <div class="search-card">
            <div class="search-wrap">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="searchInput" placeholder="<%= __('search_placeholder') %>" class="search-input" />
            </div>
        </div>

        <% if(records.length === 0) { %>
            <div class="empty-state">
                <i class="fa-solid fa-folder-open"></i>
                <p><%= __('no_records') %></p>
            </div>
        <% } else { %>

            <!-- Mobile compact cards with ALL info -->
            <div class="mobile-list">
                <% records.forEach((record, index) => { %>
                <div class="m-row">
                    <div class="m-top">
                        <div class="m-left">
                            <span class="m-no">#<%= index + 1 %></span>
                            <div class="avatar-sm avatar-green"><%= record.name.charAt(0) %></div>
                            <span class="m-name"><%= record.name %></span>
                        </div>
                        <div class="m-actions">
                            <button data-action="edit" data-id="<%= record.id %>" data-name="<%= record.name %>" data-gender="<%= record.gender %>" data-age="<%= record.age %>" data-phone="<%= record.phone %>" data-place="<%= record.place %>" class="btn-edit action-btn action-edit"><i class="fa-solid fa-pen"></i></button>
                            <button data-action="delete" data-id="<%= record.id %>" class="btn-delete action-btn action-delete"><i class="fa-solid fa-trash"></i></button>
                        </div>
                    </div>
                    <div class="m-badges">
                        <% if(record.gender === 'Male' || record.gender === 'ប្រុស') { %>
                            <span class="badge-pill badge-blue"><%= __('gender_male') %></span>
                        <% } else if(record.gender === 'Female' || record.gender === 'ស្រី') { %>
                            <span class="badge-pill badge-pink"><%= __('gender_female') %></span>
                        <% } else { %>
                            <span class="badge-pill badge-gray"><%= __('gender_other') %></span>
                        <% } %>
                        <span class="badge-pill badge-purple"><%= record.age %> yrs</span>
                    </div>
                    <div class="m-info">
                        <span class="m-info-item"><i class="fa-solid fa-phone"></i> <%= record.phone %></span>
                        <span class="m-info-item"><i class="fa-solid fa-location-dot"></i> <%= record.place %></span>
                        <span class="m-info-item"><i class="fa-regular fa-clock"></i> <%= record.time %></span>
                    </div>
                </div>
                <% }) %>
            </div>

            <!-- Desktop table -->
            <div class="table-card desktop-table">
                <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th style="text-align:center;width:50px">No.</th>
                            <th><%= __('th_name') %></th>
                            <th><%= __('th_gender') %></th>
                            <th><%= __('th_age') %></th>
                            <th><%= __('th_phone') %></th>
                            <th><%= __('th_place') %></th>
                            <th><%= __('th_time') %></th>
                            <th style="text-align:center;width:80px">.</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% records.forEach((record, index) => { %>
                        <tr>
                            <td style="text-align:center;font-weight:600;color:#94a3b8;font-family:monospace"><%= index + 1 %></td>
                            <td>
                                <div style="display:flex;align-items:center;gap:8px">
                                    <div class="avatar-sm avatar-green"><%= record.name.charAt(0) %></div>
                                    <span style="font-weight:600;color:#0f172a;font-size:12px"><%= record.name %></span>
                                </div>
                            </td>
                            <td>
                                <% if(record.gender === 'Male' || record.gender === 'ប្រុស') { %>
                                    <span class="badge-pill badge-blue"><%= __('gender_male') %></span>
                                <% } else if(record.gender === 'Female' || record.gender === 'ស្រី') { %>
                                    <span class="badge-pill badge-pink"><%= __('gender_female') %></span>
                                <% } else { %>
                                    <span class="badge-pill badge-gray"><%= __('gender_other') %></span>
                                <% } %>
                            </td>
                            <td><span class="badge-pill badge-purple"><%= record.age %></span></td>
                            <td style="font-family:monospace;color:#475569;font-size:12px"><%= record.phone %></td>
                            <td style="color:#475569;font-size:12px"><%= record.place %></td>
                            <td style="color:#94a3b8;font-weight:500;font-size:12px"><%= record.time %></td>
                            <td style="text-align:center">
                                <div style="display:flex;gap:4px;justify-content:center">
                                    <button data-action="edit" data-id="<%= record.id %>" data-name="<%= record.name %>" data-gender="<%= record.gender %>" data-age="<%= record.age %>" data-phone="<%= record.phone %>" data-place="<%= record.place %>" class="btn-edit action-btn action-edit" title="Edit"><i class="fa-solid fa-pen"></i></button>
                                    <button data-action="delete" data-id="<%= record.id %>" class="btn-delete action-btn action-delete" title="Delete"><i class="fa-solid fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
                </div>

                <% if (totalPages > 1) { %>
                <div class="pagination">
                    <div class="info">
                        <%= __('showing_page') %> <span><%= currentPage %></span> <%= __('of') %> <span><%= totalPages %></span> <%= __('pages') %>
                    </div>
                    <div class="page-btns">
                        <a href="/manager/list?page=<%= currentPage - 1 %>" class="page-btn <%= currentPage === 1 ? 'disabled' : '' %>"><i class="fa-solid fa-chevron-left" style="font-size:11px"></i></a>
                        <% 
                          let pages = [];
                          if (totalPages <= 7) {
                            for (let i = 1; i <= totalPages; i++) pages.push(i);
                          } else {
                            pages.push(1);
                            if (currentPage > 3) pages.push('...');
                            for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) {
                              pages.push(i);
                            }
                            if (currentPage < totalPages - 2) pages.push('...');
                            pages.push(totalPages);
                          }
                          pages.forEach(p => { %>
                            <% if (p === '...') { %>
                              <span class="page-btn disabled" style="pointer-events:none;border:none">...</span>
                            <% } else { %>
                              <a href="/manager/list?page=<%= p %>" class="page-btn <%= currentPage === p ? 'active' : '' %>"><%= p %></a>
                            <% } %>
                          <% }); %>
                        <a href="/manager/list?page=<%= currentPage + 1 %>" class="page-btn <%= currentPage === totalPages ? 'disabled' : '' %>"><i class="fa-solid fa-chevron-right" style="font-size:11px"></i></a>
                    </div>
                </div>
                <% } %>
            </div>
        <% } %>
    </div>

    <!-- Modal -->
    <div id="crudModal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h3 id="modalTitle">Add New</h3>
                <button id="btnCloseModal" class="modal-close"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <form id="crudForm">
                    <input type="hidden" id="recordId" name="id">
                    <input type="hidden" id="csrfInput" value="<%= csrfToken %>"
                           data-add-title="<%= __('modal_add_title') %>"
                           data-edit-title="<%= __('modal_edit_title') %>"
                           data-swal-success="<%= __('swal_success') %>"
                           data-swal-saved="<%= __('swal_saved') %>"
                           data-swal-error="<%= __('swal_error') %>"
                           data-swal-fail-msg="<%= __('swal_fail_msg') %>"
                           data-swal-confirm-title="<%= __('swal_confirm_title') %>"
                           data-swal-confirm-text="<%= __('swal_confirm_text') %>"
                           data-swal-confirm-btn="<%= __('swal_confirm_btn') %>"
                           data-swal-cancel-btn="<%= __('swal_cancel_btn') %>"
                           data-swal-deleted-title="<%= __('swal_deleted_title') %>"
                           data-swal-deleted-msg="<%= __('swal_deleted_msg') %>"
                           data-swal-delete-fail="<%= __('swal_delete_fail') %>">
                    <div class="form-group">
                        <label><%= __('th_name') %></label>
                        <input type="text" id="formName" required>
                    </div>
                    <div class="form-group">
                        <label><%= __('th_gender') %></label>
                        <select id="formGender" required>
                            <option value="Male"><%= __('gender_male') %></option>
                            <option value="Female"><%= __('gender_female') %></option>
                            <option value="Other"><%= __('gender_other') %></option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label><%= __('th_age') %></label>
                        <input type="number" id="formAge" required min="1" max="120" placeholder="22">
                    </div>
                    <div class="form-group">
                        <label><%= __('th_phone') %></label>
                        <input type="tel" id="formPhone" required>
                    </div>
                    <div class="form-group">
                        <label><%= __('th_place') %></label>
                        <input type="text" id="formPlace" required>
                    </div>
                    <div class="modal-footer">
                        <button type="button" id="btnCancelModal" class="btn btn-cancel"><%= __('btn_cancel') %></button>
                        <button type="submit" class="btn btn-save"><%= __('btn_save') %></button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="/js/manager-list.js"></script>
    <div id="recordsData" data-records="<%- JSON.stringify(records).replace(/"/g, '&quot;') %>" class="hidden"></div>
    <script src="/js/manager-list-search.js"></script>
    <script>
    document.getElementById('btnCloseModal').addEventListener('click', function(){ document.getElementById('crudModal').classList.remove('show'); });
    document.getElementById('btnCancelModal').addEventListener('click', function(){ document.getElementById('crudModal').classList.remove('show'); });
    document.getElementById('crudModal').addEventListener('click', function(e){ if(e.target === this) this.classList.remove('show'); });
    </script>
</body>
</html>
