<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= __('nav_qr') %></title>
    <link rel="icon" type="image/jpeg" href="/images/favicon.jpg" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Hanuman:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
      body{
        font-family:"Plus Jakarta Sans","Hanuman",sans-serif;
        background:linear-gradient(160deg,#f0fdf4 0%,#ecfdf5 30%,#f0f9ff 70%,#eff6ff 100%);
        min-height:100vh;color:#0f172a;position:relative;overflow:hidden;
      }
      body::before{
        content:'';position:absolute;top:-40%;right:-20%;width:500px;height:500px;
        background:radial-gradient(circle,rgba(34,197,94,0.08) 0%,transparent 70%);
        border-radius:50%;animation:float1 10s ease-in-out infinite alternate;
      }
      body::after{
        content:'';position:absolute;bottom:-30%;left:-15%;width:400px;height:400px;
        background:radial-gradient(circle,rgba(59,130,246,0.06) 0%,transparent 70%);
        border-radius:50%;animation:float2 12s ease-in-out infinite alternate;
      }
      @keyframes float1{0%{transform:translate(0,0)}100%{transform:translate(30px,20px)}}
      @keyframes float2{0%{transform:translate(0,0)}100%{transform:translate(-20px,-30px)}}
      .page-wrapper{position:relative;z-index:1;max-width:1200px;margin:0 auto;padding:20px 16px}
      .content{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:calc(100vh - 100px)}

      .card{
        background:#fff;border-radius:24px;padding:44px 36px;text-align:center;
        box-shadow:0 4px 6px -1px rgba(0,0,0,.03),0 20px 50px -12px rgba(0,0,0,.06);
        border:1px solid rgba(0,0,0,.04);max-width:440px;width:100%;
        animation:cardUp .5s ease-out .1s both;
      }
      @keyframes cardUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

      .icon-ring{
        width:80px;height:80px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;
        box-shadow:0 8px 24px rgba(22,163,74,0.12);margin-bottom:20px;
        animation:popIn .5s cubic-bezier(.175,.885,.32,1.275) .2s both;
        overflow:hidden;
      }
      @keyframes popIn{from{opacity:0;transform:scale(.5)}to{opacity:1;transform:scale(1)}}
      .icon-ring img{width:100%;height:100%;object-fit:cover;border-radius:50%}

      .card h2{font-size:20px;font-weight:700;color:#0f172a;margin-bottom:6px;letter-spacing:-.02em}
      .card>p{color:#94a3b8;font-size:13px;margin-bottom:28px}

      .qr-frame{
        position:relative;display:inline-block;padding:16px;
        background:#f8fafc;border-radius:20px;border:1px solid #e2e8f0;
        margin-bottom:24px;animation:cardUp .5s ease-out .2s both;
      }
      .qr-frame .corner{position:absolute;width:20px;height:20px}
      .qr-frame .corner.tl{top:8px;left:8px;border-top:3px solid #22c55e;border-left:3px solid #22c55e;border-radius:4px 0 0 0}
      .qr-frame .corner.tr{top:8px;right:8px;border-top:3px solid #22c55e;border-right:3px solid #22c55e;border-radius:0 4px 0 0}
      .qr-frame .corner.bl{bottom:8px;left:8px;border-bottom:3px solid #22c55e;border-left:3px solid #22c55e;border-radius:0 0 0 4px}
      .qr-frame .corner.br{bottom:8px;right:8px;border-bottom:3px solid #22c55e;border-right:3px solid #22c55e;border-radius:0 0 4px 0}
      .qr-frame img{
        display:block;width:220px;height:220px;background:#fff;border-radius:14px;
        border:1px solid #e2e8f0;padding:8px;transition:transform .3s ease;
      }
      .qr-frame img:hover{transform:scale(1.02)}

      .btn-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;animation:cardUp .5s ease-out .3s both}
      .btn{
        padding:13px;border-radius:12px;font-size:13px;font-weight:600;font-family:inherit;
        cursor:pointer;border:none;display:flex;align-items:center;justify-content:center;gap:8px;
        transition:all .25s ease;text-decoration:none;
      }
      .btn-primary{
        background:linear-gradient(135deg,#3b82f6,#2563eb);color:#fff;
        box-shadow:0 4px 12px rgba(59,130,246,0.25);
      }
      .btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(59,130,246,0.35)}
      .btn-secondary{background:#f1f5f9;color:#475569;border:1.5px solid #e2e8f0}
      .btn-secondary:hover{background:#e2e8f0;transform:translateY(-1px)}

      .hint{
        margin-top:20px;color:#94a3b8;font-size:11px;
        display:flex;align-items:center;justify-content:center;gap:6px;
        animation:cardUp .5s ease-out .35s both;
      }
      .hint i{color:#3b82f6}
    </style>
  </head>
  <body data-qr-title="<%= __('qr_image_title') %>" data-qr-instruction="<%= __('qr_image_instruction') %>">
    <div class="page-wrapper">
      <%- include('navbar') %>
      <div class="content">
        <div class="card">
          <div class="icon-ring"><img src="/images/logo.jpg" alt="Logo" /></div>
          <h2><%= __('qr_title') %></h2>
          <p><%= __('qr_subtitle') %></p>

          <div class="qr-frame">
            <span class="corner tl"></span>
            <span class="corner tr"></span>
            <span class="corner bl"></span>
            <span class="corner br"></span>
            <img id="qrImage" src="<%= qrCodeDataUrl %>" alt="Attendance QR Code" />
          </div>

          <div class="btn-row">
            <button id="btnDownloadQR" class="btn btn-primary">
              <i class="fa-solid fa-arrow-down-to-line"></i> <%= __('btn_download') %>
            </button>
            <button id="btnShareQR" class="btn btn-secondary">
              <i class="fa-solid fa-share-nodes"></i> <%= __('btn_share') %>
            </button>
            <button id="btnPrintQR" class="btn btn-secondary">
              <i class="fa-solid fa-print"></i> <%= __('btn_print') %>
            </button>
          </div>

          <div class="hint">
            <i class="fa-solid fa-circle-info"></i> <%= __('qr_network_hint') %>
          </div>
        </div>
      </div>
    </div>
    <script src="/js/manager-qr.js"></script>
  </body>
</html>
