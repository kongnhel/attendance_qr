<!DOCTYPE html>
<html lang="km">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ចូលប្រើប្រាស់ប្រព័ន្ធ</title>
    <link rel="icon" type="image/jpeg" href="/images/favicon.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Hanuman:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
      body {
        font-family: "Plus Jakarta Sans", "Hanuman", sans-serif;
        min-height: 100vh; display: flex; align-items: center; justify-content: center;
        padding: 20px;
        background: linear-gradient(160deg, #f0fdf4 0%, #ecfdf5 30%, #f0f9ff 70%, #eff6ff 100%);
        position: relative; overflow: hidden;
      }
      body::before {
        content: ''; position: absolute; top: -40%; right: -20%;
        width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(34,197,94,0.08) 0%, transparent 70%);
        border-radius: 50%; animation: float1 10s ease-in-out infinite alternate;
      }
      body::after {
        content: ''; position: absolute; bottom: -30%; left: -15%;
        width: 400px; height: 400px;
        background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 70%);
        border-radius: 50%; animation: float2 12s ease-in-out infinite alternate;
      }
      @keyframes float1{0%{transform:translate(0,0)}100%{transform:translate(30px,20px)}}
      @keyframes float2{0%{transform:translate(0,0)}100%{transform:translate(-20px,-30px)}}

      .wrapper{width:100%;max-width:420px;position:relative;z-index:1}

      .brand-bar{text-align:center;margin-bottom:24px;animation:fadeDown .5s ease-out}
      @keyframes fadeDown{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:translateY(0)}}
      .brand-bar .logo{
        width:80px;height:80px;
        border-radius:50%;display:inline-flex;align-items:center;justify-content:center;
        box-shadow:0 8px 24px rgba(22,163,74,0.2);margin-bottom:14px;
        overflow:hidden;
      }
      .brand-bar .logo img{width:100%;height:100%;object-fit:cover;border-radius:50%}
      .brand-bar h1{color:#0f172a;font-size:22px;font-weight:800;letter-spacing:-.03em;margin-bottom:4px}
      .brand-bar p{color:#94a3b8;font-size:13px;font-weight:500}

      .card{
        background:#fff;border-radius:24px;padding:40px 32px 32px;
        box-shadow:0 4px 6px -1px rgba(0,0,0,.03),0 20px 50px -12px rgba(0,0,0,.06);
        border:1px solid rgba(0,0,0,.04);animation:cardUp .5s ease-out .1s both;
      }
      @keyframes cardUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

      .card-header{text-align:center;margin-bottom:28px}
      .card-header h2{color:#0f172a;font-size:18px;font-weight:700;margin-bottom:4px}
      .card-header p{color:#94a3b8;font-size:13px}

      .divider{height:1px;background:linear-gradient(90deg,transparent,#e2e8f0,transparent);margin-bottom:24px}

      .avatar-ring{
        width:80px;height:80px;border-radius:50%;margin:0 auto 20px;
        display:flex;align-items:center;justify-content:center;
        background:linear-gradient(135deg,#dcfce7,#bbf7d0);
        box-shadow:0 8px 32px rgba(34,197,94,0.12);animation:popIn .5s cubic-bezier(.175,.885,.32,1.275) .2s both;
      }
      @keyframes popIn{from{opacity:0;transform:scale(.5)}to{opacity:1;transform:scale(1)}}
      .avatar-ring img{width:72px;height:72px;border-radius:50%;object-fit:cover;border:3px solid #fff}
      .avatar-ring i{font-size:32px;color:#16a34a}

      .error-box{
        color:#dc2626;background:#fef2f2;border:1px solid #fee2e2;
        padding:12px 14px;border-radius:12px;margin-bottom:20px;font-size:13px;font-weight:500;
        display:flex;align-items:center;gap:8px;justify-content:center;
        animation:fieldUp .3s ease-out;
      }

      .form-group{margin-bottom:18px;animation:fieldUp .4s ease-out both}
      .form-group:nth-child(1){animation-delay:.15s}
      .form-group:nth-child(2){animation-delay:.2s}
      @keyframes fieldUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

      .field-label{
        display:flex;align-items:center;gap:6px;margin-bottom:8px;
        font-size:12px;font-weight:600;color:#64748b;
        text-transform:uppercase;letter-spacing:.06em;
      }
      .field-label i{font-size:11px;color:#16a34a}
      .field-label .req{color:#ef4444;margin-left:2px}

      .input-wrap{position:relative}
      .input-wrap i.field-icon{
        position:absolute;left:14px;top:50%;transform:translateY(-50%);
        font-size:14px;color:#cbd5e1;pointer-events:none;transition:color .2s;
      }
      .input-wrap:focus-within i.field-icon{color:#16a34a}

      .input-wrap .toggle-pass{
        position:absolute;right:14px;top:50%;transform:translateY(-50%);
        font-size:15px;color:#cbd5e1;cursor:pointer;transition:color .2s;
        background:none;border:none;padding:0;
      }
      .input-wrap .toggle-pass:hover{color:#16a34a}

      input[type="text"],input[type="password"]{
        width:100%;padding:13px 14px 13px 42px;
        background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:12px;
        font-size:14px;font-family:inherit;color:#0f172a;
        transition:all .25s ease;outline:none;
      }
      input::placeholder{color:#94a3b8}
      input:focus{border-color:#22c55e;background:#fff;box-shadow:0 0 0 3px rgba(34,197,94,0.1)}

      .btn-submit{
        width:100%;padding:15px;margin-top:8px;
        background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;
        border:none;border-radius:14px;font-size:15px;font-weight:700;
        font-family:inherit;cursor:pointer;
        display:flex;align-items:center;justify-content:center;gap:10px;
        box-shadow:0 4px 16px rgba(22,163,74,0.25);
        transition:all .3s ease;animation:fieldUp .4s ease-out .25s both;
        position:relative;overflow:hidden;
      }
      .btn-submit::before{
        content:'';position:absolute;top:0;left:-100%;
        width:100%;height:100%;
        background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent);
        transition:left .5s ease;
      }
      .btn-submit:hover::before{left:100%}
      .btn-submit:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(22,163,74,0.35)}
      .btn-submit:active{transform:translateY(0)}

      .footer-note{text-align:center;margin-top:20px;color:#94a3b8;font-size:11px;animation:fieldUp .4s ease-out .35s both}
      .footer-note i{color:#22c55e}
      @media(prefers-reduced-motion:reduce){
        *,*::before,*::after{animation-duration:0.01ms !important;animation-iteration-count:1 !important;transition-duration:0.01ms !important}
        body::before,body::after{animation:none !important}
      }
      @media(prefers-reduced-motion:reduce),(max-width:480px){
        .card-up,.fadeDown,.cardUp,.fieldUp{animation:none !important;opacity:1 !important;transform:none !important}
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="brand-bar">
        <div class="logo"><img src="/images/logo.jpg" alt="Logo" loading="lazy" width="80" height="80" /></div>
        <h1>QR Attendance</h1>
        <p>ប្រព័ន្ធគ្រប់គ្រងវត្តមាន</p>
      </div>

      <div class="card">
        <div class="card-header">
          <div class="avatar-ring">
            <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
              <img src="<%= logoUrl %>" alt="Logo" />
            <% } else { %>
              <i class="fa-solid fa-user-shield"></i>
            <% } %>
          </div>
          <h2>ស្វាគមន៍ត្រឡប់មកវិញ</h2>
          <p>សូមបញ្ចូលគណនីរបស់អ្នកដើម្បីចូល</p>
        </div>
        <div class="divider"></div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-box">
            <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
          </div>
        <% } %>

        <form action="/admin/login" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />

          <div class="form-group">
            <label class="field-label">
              <i class="fa-solid fa-user"></i> ឈ្មោះគណនី <span class="req">*</span>
            </label>
            <div class="input-wrap">
              <i class="fa-solid fa-at field-icon"></i>
              <input type="text" name="username" placeholder="admin" required />
            </div>
          </div>

          <div class="form-group">
            <label class="field-label">
              <i class="fa-solid fa-lock"></i> លេខសម្ងាត់ <span class="req">*</span>
            </label>
            <div class="input-wrap">
              <i class="fa-solid fa-key field-icon"></i>
              <input type="password" name="password" id="passInput" placeholder="••••••••" required />
              <button type="button" class="toggle-pass" id="togglePass">
                <i class="fa-solid fa-eye" id="eyeIcon"></i>
              </button>
            </div>
          </div>

          <button type="submit" class="btn-submit">
            ចូលប្រើប្រាស់ <i class="fa-solid fa-arrow-right-to-bracket"></i>
          </button>
        </form>
      </div>

      <div class="footer-note">
        <i class="fa-solid fa-shield-halved"></i> ប្រព័ន្ធគ្រប់គ្រងវត្តមាន QR
      </div>
    </div>
    <script src="/js/login.js"></script>
  </body>
</html>
