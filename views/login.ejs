<!DOCTYPE html>
<html lang="km">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ចូលប្រើប្រាស់ប្រព័ន្ធ</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Hanuman:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body { 
            font-family: 'Plus Jakarta Sans', 'Hanuman', 'Khmer OS', 'Khmer OS Battambang', -apple-system, sans-serif; 
            background: radial-gradient(circle at 50% 50%, #f8fafc 0%, #f1f5f9 100%);
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            color: #0f172a;
        }
        .login-container { 
            background: #ffffff; 
            padding: 40px; 
            border-radius: 24px; 
            box-shadow: 0 20px 25px -5px rgba(15, 23, 42, 0.05), 0 10px 10px -5px rgba(15, 23, 42, 0.04); 
            width: 100%; 
            max-width: 400px; 
            border: 1px solid rgba(241, 245, 249, 0.8);
        }
        
        /* កន្លែងរូបភាព Profile ឬ Header */
        .login-header {
            text-align: center;
            margin-bottom: 32px;
        }
        .profile-wrapper {
            display: inline-block;
            position: relative;
            margin-bottom: 16px;
        }
        .login-avatar {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #ffffff;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
        }
        h2 { 
            font-size: 22px;
            font-weight: 700;
            color: #0f172a;
            font-family: 'Hanuman', 'Khmer OS', 'Khmer OS Battambang', serif;
            letter-spacing: -0.02em;
        }
        .subtitle {
            font-size: 13px;
            color: #64748b;
            margin-top: 6px;
            font-family: 'Hanuman', 'Khmer OS', 'Khmer OS Battambang', serif;
        }

        .form-group { 
            margin-bottom: 20px; 
        }
        label { 
            display: block; 
            margin-bottom: 6px; 
            color: #475569; 
            font-size: 13px;
            font-weight: 600;
            font-family: 'Hanuman', 'Khmer OS', 'Khmer OS Battambang', serif;
        }
        input { 
            width: 100%; 
            padding: 12px 16px; 
            border: 1px solid #cbd5e1; 
            border-radius: 12px; 
            font-size: 14px;
            font-family: inherit;
            color: #0f172a;
            background-color: #f8fafc;
            transition: all 0.2s ease-in-out;
        }
        /* ពេលចុចលើប្រអប់វាយអក្សរ វាឡើងពន្លឺខៀវស្រទន់ទាក់ទាញភ្នែក */
        input:focus {
            outline: none;
            border-color: #3b82f6;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }
        
        button { 
            width: 100%; 
            padding: 14px; 
            background-color: #0f172a; /* ពណ៌ខ្មៅដិតបែបប្រណីត */
            color: white; 
            border: none; 
            border-radius: 12px; 
            font-size: 14px; 
            cursor: pointer; 
            font-weight: 600; 
            transition: all 0.2s ease;
            margin-top: 8px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            font-family: inherit;
        }
        button:hover { 
            background-color: #1e293b; 
            transform: translateY(-1px);
        }
        button:active {
            transform: translateY(0);
        }

        /* ប្រអប់ប្រាប់កំហុស (Error) លេងស្ទីលកាចបែបថ្លៃថ្នូរ */
        .error { 
            color: #b91c1c; 
            background-color: #fef2f2;
            border: 1px solid #fee2e2;
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 20px; 
            font-size: 13px; 
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            justify-content: center;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-header">
            <div class="profile-wrapper">
                <img class="login-avatar" src="/images/logo.jpg" alt="Profile Picture">
            </div>
            <h2>ស្វាគមន៍ត្រឡប់មកវិញ</h2>
            <p class="subtitle">សូមបញ្ចូលគណនីរបស់អ្នកដើម្បីចូលទៅកាន់ផ្ទាំងគ្រប់គ្រង</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                <%= error %>
            </div>
        <% } %>

        <form action="/admin/login" method="POST">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

            <div class="form-group">
                <label>ឈ្មោះគណនី (Username)</label>
                <input type="text" name="username" placeholder="ឧទាហរណ៍៖ admin" required>
            </div>
            <div class="form-group">
                <label>លេខសម្ងាត់ (Password)</label>
                <input type="password" name="password" placeholder="••••••••" required> 
            </div>
            <button type="submit">
                ចូលប្រើប្រាស់
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
        </form>
    </div>

</body>
</html>